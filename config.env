# IP address of the computer on the rover
ROVER_IP = "127.0.0.1"

# Ports for different servers
CAMERA_FEED_PORT = 8995
MQTT_BROKER_PORT = 1883
MAPTILE_SERVER_PORT = 3650

# MQTT Settings
SAMPLE_TOPIC = "sensors/temperature"
SAMPLE_TOPIC2 = "sensors/temperature2"
IMU_TOPIC = "sensors/imu"
GNSS_TOPIC = "sensors/gnss"

# Maptiler Server Settings
